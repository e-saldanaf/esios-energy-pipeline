# ESIOS API — request your free personal token at consultasios@ree.es
ESIOS_API_TOKEN=your_token_here

# Supabase — use the SESSION pooler (port 5432), NOT transaction mode (6543).
# Our temp-table + MERGE pattern requires session-scoped connections.
DB_HOST=aws-0-eu-west-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.yourprojectref
DB_PASSWORD=your_password_here
LOG_FORMAT=text